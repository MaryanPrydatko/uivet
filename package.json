{
  "name": "uivet",
  "version": "0.1.0",
  "type": "module",
  "description": "Test and eval harness for LLM-generated UI",
  "license": "MIT",
  "scripts": {
    "run": "bun run src/cli.ts run",
    "demo": "bun run src/cli.ts run --config examples/uivet.config.ts",
    "demo:offline": "bun run src/cli.ts run --config examples/uivet.offline.config.ts",
    "lint": "biome check",
    "lint:fix": "biome check --write"
  },
  "dependencies": {
    "axe-core": "^4.10.2",
    "playwright": "^1.49.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/bun": "^1.3.14",
    "typescript": "^7.0.2",
    "ultracite": "^7.9.4"
  },
  "bin": {
    "uivet": "src/cli.ts"
  }
}
